{
  "name": "obsidian-creases",
  "version": "0.7.6",
  "description": "Configurable folding within Obsidian",
  "author": "liamcain",
  "main": "main.js",
  "license": "MIT",
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "lint": "eslint .",
    "dev": "node --env-file-if-exists=.env esbuild.config.mjs",
    "build": "pnpm run lint && node esbuild.config.mjs production",
    "build:ci": "node esbuild.config.mjs production",
    "build:local": "node --env-file-if-exists=.env scripts/build-local.mjs",
    "release": "standard-version"
  },
  "engines": {
    "node": ">=22.9.0"
  },
  "standard-version": {
    "t": "",
    "bumpFiles": [
      {
        "filename": "package.json",
        "type": "json"
      },
      {
        "filename": "manifest.json",
        "type": "json"
      }
    ]
  },
  "devDependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "@eslint/js": "9.30.1",
    "@types/node": "^16.11.6",
    "cz-conventional-changelog": "3.3.0",
    "esbuild": "0.13.12",
    "eslint": "9.30.1",
    "eslint-plugin-obsidianmd": "0.2.9",
    "globals": "14.0.0",
    "jiti": "2.6.1",
    "monkey-around": "2.3.0",
    "obsidian": "obsidianmd/obsidian-api#4c5889aa06d3ceb3d4d3a20931fbeaede6d399a0",
    "standard-version": "^9.3.2",
    "tslib": "2.5.0",
    "typescript": "5.6.3",
    "typescript-eslint": "8.35.1"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
